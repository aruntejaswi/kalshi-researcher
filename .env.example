# Kalshi V2 API credentials
# Obtain from https://kalshi.com -> API keys. Export the RSA private key as PEM.
KALSHI_KEY_ID=your-key-id-uuid-here
KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi_private_key.pem

# Optional: override Kalshi endpoints (defaults point to production elections API)
# KALSHI_REST_BASE=https://api.elections.kalshi.com/trade-api/v2
# KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2

# Research skills — leave blank to use the deterministic mock
TAVILY_API_KEY=

# Analyzer LLM
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
